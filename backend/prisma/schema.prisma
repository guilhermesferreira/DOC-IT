generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserGroup {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  users       User[]

  // Permissões: Módulo de Usuários
  canViewUsers   Boolean @default(false)
  canCreateUsers Boolean @default(false)
  canEditUsers   Boolean @default(false)
  canDeleteUsers Boolean @default(false)

  // Permissões: Módulo RBAC (Grupos)
  canViewGroups   Boolean @default(false)
  canCreateGroups Boolean @default(false)
  canEditGroups   Boolean @default(false)
  canDeleteGroups Boolean @default(false)

  // Permissões: Módulo Dispositivos / Inventário
  canViewDevices   Boolean @default(false)
  canManageDevices Boolean @default(false) // Aprovar, rejeitar, arquivar

  // Permissões: Módulo Acesso Remoto (Agentes)
  canAccessRemote  Boolean @default(false) // Acesso especifico de seguranca pro Web Terminal / VNC

  // Permissões: Módulo Configurações Globais (Settings)
  canViewSettings  Boolean @default(false)
  canEditSettings  Boolean @default(false)

  // Permissões: Módulo de Auditoria
  canViewAuditLogs     Boolean @default(false)
  canViewAuditSettings Boolean @default(false)
  canEditAuditSettings Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id             Int        @id @default(autoincrement())
  username       String     @unique
  email          String     @unique
  password       String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  mfaSecret      String?
  isMfaEnabled   Boolean    @default(false)
  groupId        Int?
  authProvider   String     @default("local")
  domainUsername String?    @unique
  devices        Device[]
  auditLogs      AuditLog[] // Relacionamento com os logs gerados pelo usuário
  group          UserGroup? @relation(fields: [groupId], references: [id])
}

model Device {
  id             Int       @id @default(autoincrement())
  name           String
  type           String
  location       String
  patrimony      String?
  userId         Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  agentId        String?   @unique
  hostname       String?
  osUsername     String?
  ipAddress      String?
  agentVersion   String?
  osInfo         String?
  additionalData Json?
  status         String    @default("pending")
  source         String    @default("manual")
  firstSeenAt    DateTime?
  lastSeenAt     DateTime?
  approvedAt     DateTime?
  certRenewalPending Boolean @default(false)
  user           User?     @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([hostname])
  @@index([userId])
  @@index([agentId])
  @@index([source])
}

model GlobalSettings {
  id                         Int      @id @default(autoincrement())
  inventoryIntervalMinutes   Int      @default(60)
  updateCheckIntervalMinutes Int      @default(120)
  updatedAt                  DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String   // ex: CREATE, UPDATE, DELETE, ACCESS, COMMAND
  resource  String   // ex: DEVICE, USER, GROUP, TERMINAL, SETTINGS
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

model AuditConfig {
  id                  Int      @id @default(1)
  logUserActions      Boolean  @default(true)
  logDeviceActions    Boolean  @default(true)
  logTerminalAccess   Boolean  @default(true)
  logTerminalCommands Boolean  @default(false) // Desligado por padrão por segurança/volume
  logSettingsChanges  Boolean  @default(true)
  retentionDays       Int      @default(30)
  updatedAt           DateTime @updatedAt
}
